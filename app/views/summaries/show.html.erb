<% content_for :title, t(".title", alias: @house.alias) %>

<%= render "shared/back_link", to: @house, label: t("common.go_inspection") %>
<h1 class="mt-2 mb-4 text-2xl font-semibold text-slate-900 dark:text-slate-100 break-keep"><%= t(".title", alias: @house.alias) %></h1>

<div class="mb-6 grid grid-cols-2 gap-2 sm:grid-cols-4">
  <div class="rounded-lg border border-red-400 bg-red-100 p-3 text-center dark:border-red-500/50 dark:bg-red-900/30">
    <div class="text-sm font-medium text-red-800 dark:text-red-300"><%= t("inspection_checks.severity.severe") %></div>
    <div class="mt-1 text-xl font-bold text-red-800 dark:text-red-300 tabular-nums"><%= @summary.counts[:severe] %></div>
  </div>
  <div class="rounded-lg border border-yellow-400 bg-yellow-100 p-3 text-center dark:border-yellow-500/50 dark:bg-yellow-900/30">
    <div class="text-sm font-medium text-yellow-900 dark:text-yellow-300"><%= t("inspection_checks.severity.warn") %></div>
    <div class="mt-1 text-xl font-bold text-yellow-900 dark:text-yellow-300 tabular-nums"><%= @summary.counts[:warn] %></div>
  </div>
  <div class="rounded-lg border border-green-400 bg-green-100 p-3 text-center dark:border-green-500/50 dark:bg-green-900/30">
    <div class="text-sm font-medium text-green-800 dark:text-green-300"><%= t("inspection_checks.severity.ok") %></div>
    <div class="mt-1 text-xl font-bold text-green-800 dark:text-green-300 tabular-nums"><%= @summary.counts[:ok] %></div>
  </div>
  <div class="rounded-lg border border-slate-300 bg-slate-100 p-3 text-center dark:border-slate-700 dark:bg-slate-800">
    <div class="text-sm font-medium text-slate-700 dark:text-slate-300"><%= t("inspection_checks.status.unchecked") %></div>
    <div class="mt-1 text-xl font-bold text-slate-700 dark:text-slate-300 tabular-nums"><%= @summary.counts[:unchecked] %></div>
  </div>
</div>

<% if @summary.severe_items.any? %>
  <section class="mb-6">
    <h2 class="mb-2 text-base font-semibold text-red-700 dark:text-red-400 break-keep"><%= t(".severe_heading", count: @summary.severe_items.size) %></h2>
    <ul class="space-y-2">
      <% @summary.severe_items.each do |entry| %>
        <li class="border-l-4 border-red-500 pl-3 py-1 dark:border-red-400">
          <div class="text-base font-medium text-slate-900 dark:text-slate-100 break-keep"><%= item_label(entry[:item]) %></div>
          <div class="text-sm text-slate-400 dark:text-slate-500 break-keep"><%= domain_label(Checklist.domains.find { |d| d.key == entry[:item].domain }) %></div>
          <% if entry[:check].memo.present? %>
            <div class="mt-1 text-sm text-slate-700 dark:text-slate-300 break-keep">└ <%= entry[:check].memo %></div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<% if @summary.warn_items.any? %>
  <section class="mb-6">
    <h2 class="mb-2 text-base font-semibold text-yellow-700 dark:text-yellow-400 break-keep"><%= t(".warn_heading", count: @summary.warn_items.size) %></h2>
    <ul class="space-y-2">
      <% @summary.warn_items.each do |entry| %>
        <li class="border-l-4 border-yellow-500 pl-3 py-1 dark:border-yellow-400">
          <div class="text-base font-medium text-slate-900 dark:text-slate-100 break-keep"><%= item_label(entry[:item]) %></div>
          <div class="text-sm text-slate-400 dark:text-slate-500 break-keep"><%= domain_label(Checklist.domains.find { |d| d.key == entry[:item].domain }) %></div>
          <% if entry[:check].memo.present? %>
            <div class="mt-1 text-sm text-slate-700 dark:text-slate-300 break-keep">└ <%= entry[:check].memo %></div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<% if @summary.unchecked_items.any? %>
  <details class="mb-6 rounded-md border border-slate-200 dark:border-slate-700">
    <summary class="flex min-h-11 cursor-pointer items-center justify-between gap-2 rounded-md px-3 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:text-slate-400 dark:hover:bg-slate-800 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 break-keep">
      <span><%= t(".unchecked_expand", count: @summary.unchecked_items.size) %></span>
      <%= icon "chevron-down", library: "heroicons", variant: "outline", class: "w-4 h-4" %>
    </summary>
    <ul class="space-y-1 px-3 py-2 text-sm text-slate-700 dark:text-slate-300">
      <% @summary.unchecked_items.each do |item| %>
        <li class="flex items-center gap-2 break-keep">
          <%= icon "chevron-right", library: "heroicons", variant: "outline", class: "w-4 h-4 text-slate-400 dark:text-slate-500 flex-shrink-0" %>
          <span><%= item_label(item) %></span>
        </li>
      <% end %>
    </ul>
  </details>
<% end %>

<% if @summary.deleted_items.any? %>
  <details class="mb-6 rounded-md border border-slate-200 dark:border-slate-700">
    <summary class="flex min-h-11 cursor-pointer items-center justify-between gap-2 rounded-md px-3 text-sm font-medium text-slate-500 transition-colors hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:text-slate-500 dark:hover:bg-slate-800 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 break-keep">
      <span><%= t(".deleted_heading", count: @summary.deleted_items.size) %></span>
      <%= icon "chevron-down", library: "heroicons", variant: "outline", class: "w-4 h-4" %>
    </summary>
    <ul class="space-y-1 px-3 py-2 text-sm text-slate-500 dark:text-slate-500">
      <% @summary.deleted_items.each do |check| %>
        <li class="flex items-center gap-2 break-keep">
          <%= icon "chevron-right", library: "heroicons", variant: "outline", class: "w-4 h-4 text-slate-400 dark:text-slate-600 flex-shrink-0" %>
          <span><%= check.item_key %></span>
        </li>
      <% end %>
    </ul>
  </details>
<% end %>
