<nav aria-label="<%= t("layout.locale_switcher.ko") %> / <%= t("layout.locale_switcher.en") %>" class="flex items-center gap-2 text-sm">
  <% I18n.available_locales.each_with_index do |loc, idx| %>
    <% if idx > 0 %>
      <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">·</span>
    <% end %>
    <% if loc == I18n.locale %>
      <span aria-current="true" class="font-semibold text-slate-900 dark:text-slate-100"><%= t("layout.locale_switcher.#{loc}") %></span>
    <% else %>
      <%= link_to t("layout.locale_switcher.#{loc}"), url_for(locale: loc),
          class: "rounded-md text-slate-600 transition-colors hover:text-blue-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:text-slate-400 dark:hover:text-blue-400 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900" %>
    <% end %>
  <% end %>
</nav>
