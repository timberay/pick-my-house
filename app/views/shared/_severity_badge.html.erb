<%
  # locals: severity (nil/:ok/:warn/:severe)
  variants = {
    ok:     "bg-green-50 text-green-700 ring-green-600/20 dark:bg-green-900/30 dark:text-green-400 dark:ring-green-400/20",
    warn:   "bg-yellow-50 text-yellow-700 ring-yellow-600/20 dark:bg-yellow-900/30 dark:text-yellow-400 dark:ring-yellow-400/20",
    severe: "bg-red-50 text-red-700 ring-red-600/20 dark:bg-red-900/30 dark:text-red-400 dark:ring-red-400/20"
  }
  labels = { ok: "양호", warn: "주의", severe: "심각" }
  key = severity&.to_sym
%>
<% if key %>
  <span class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium ring-1 ring-inset break-keep <%= variants[key] %>">
    <%= labels[key] %>
  </span>
<% end %>
