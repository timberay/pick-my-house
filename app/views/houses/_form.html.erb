<%= form_with(model: house, class: "space-y-5") do |f| %>
  <% if house.errors.any? %>
    <div class="rounded-md border border-red-400 bg-red-100 p-3 text-sm text-red-800 dark:border-red-500 dark:bg-red-900/30 dark:text-red-300 break-keep" role="alert">
      <% house.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/text_input", form: f, field: :alias,
        label: "집 별칭", required: true, maxlength: 50,
        placeholder: "예: 신반포 32평" %>

  <%= render "shared/text_input", form: f, field: :address,
        label: "주소" %>

  <%= render "shared/text_input", form: f, field: :agent_contact,
        label: "중개인 (이름/전화)" %>

  <% f.object.visited_at ||= Date.current %>
  <%= render "shared/text_input", form: f, field: :visited_at,
        label: "방문일", type: :date %>

  <div class="border-t border-slate-200 pt-5 dark:border-slate-700">
    <button type="submit" class="<%= ui_button_classes(variant: :primary, size: :md, full_width: true) %>">
      <%= icon "check", library: "heroicons", variant: "outline", class: "w-5 h-5" %>
      <span>저장</span>
    </button>
  </div>
<% end %>
